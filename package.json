{
  "name": "t1-broker-platform",
  "version": "1.0.0",
  "description": "T1 Broker — Multi-asset brokerage platform with Saxo Bank & DriveWealth integration",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "db:migrate": "node database/migrate.js",
    "db:seed": "node database/seed.js",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "db:knex:migrate": "knex migrate:latest --knexfile database/knexfile.js",
    "db:knex:rollback": "knex migrate:rollback --knexfile database/knexfile.js",
    "test": "NODE_ENV=test jest --coverage --forceExit --detectOpenHandles",
    "test:unit": "NODE_ENV=test jest tests/unit/ --coverage",
    "test:integration": "NODE_ENV=test jest tests/integration/ --forceExit --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch",
    "lint": "eslint server/ --ext .js",
    "lint:fix": "eslint server/ --ext .js --fix",
    "health": "curl -s http://localhost:3000/api/v1/health | jq .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.12.0",
    "knex": "^3.1.0",
    "ioredis": "^5.3.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "crypto-js": "^4.2.0",
    "axios": "^1.6.5",
    "ws": "^8.16.0",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1",
    "cookie-parser": "^1.4.6",
    "multer": "^1.4.5-lts.1",
    "express-slow-down": "^2.0.1",
    "hpp": "^0.2.3",
    "xss-clean": "^0.1.4",
    "prom-client": "^15.1.0",
    "@sendgrid/mail": "^8.1.0",
    "aws-sdk": "^2.1540.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-security": "^2.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": ["/node_modules/", "/tests/fixtures/"],
    "testPathIgnorePatterns": ["/node_modules/"],
    "collectCoverageFrom": ["server/**/*.js", "!server/index.js"],
    "coverageThresholds": {
      "global": { "branches": 60, "functions": 70, "lines": 70, "statements": 70 }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
